# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Google Drive (optional, for v0.2+)
# GOOGLE_DRIVE_FOLDER_ID=...

# Turso database (optional, for cloud deployment v0.4+)
# TURSO_DATABASE_URL=libsql://...
# TURSO_AUTH_TOKEN=...

# MCP auth (optional, for cloud deployment v0.4+)
# MCP_BEARER_TOKEN=...
