# ── Oncofiles MCP Server — Environment Variables ─────────────────────────────

# Anthropic API key (required for AI summaries, metadata extraction, OCR)
ANTHROPIC_API_KEY=

# SQLite database path (default: data/oncofiles.db)
# DATABASE_PATH=data/oncofiles.db

# ── Google Drive sync ────────────────────────────────────────────────────────
# Root folder ID in Google Drive
# GOOGLE_DRIVE_FOLDER_ID=
# Service account credentials (base64-encoded JSON, for Railway)
# GOOGLE_CREDENTIALS_BASE64=
# Or path to credentials file (local dev)
# GOOGLE_APPLICATION_CREDENTIALS=

# ── Google OAuth 2.0 (for user-context GDrive operations) ────────────────────
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/oauth/callback

# ── Turso (cloud SQLite — production) ────────────────────────────────────────
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# ── MCP transport ────────────────────────────────────────────────────────────
# "stdio" for local CLI, "streamable-http" for cloud deployment
# MCP_TRANSPORT=stdio
# MCP_HOST=0.0.0.0
# MCP_PORT=8000
# MCP_BEARER_TOKEN=  # optional static token for dev/testing

# ── Sync scheduler ──────────────────────────────────────────────────────────
# SYNC_INTERVAL_MINUTES=30
# SYNC_ENABLED=true

# ── Localization ─────────────────────────────────────────────────────────────
# ONCOFILES_PREFERRED_LANG=sk

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
